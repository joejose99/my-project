            <LinearLayout
                android:id="@+id/linearLayout20"
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:layout_margin="10dp"
                android:layout_height="wrap_content">
    <TextView
        android:id="@+id/txtLogin2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold|italic"
        android:ems="10"
        android:gravity="left"
        android:text="Login"
        android:textColor="#000000"
        android:textSize="19dp"/>

            </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayout18"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:layout_margin="30dp"

        android:background="@drawable/txtbg1"
        android:layout_height="wrap_content">

        <!--
         style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                     -->


        <!-- Office details starts here


         -->


        <com.google.android.material.textfield.TextInputLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundColor="@color/transparents"


            app:hintTextColor="@color/boxStrokeColor"
            app:boxStrokeColor="@color/boxStrokeColor"
            android:id="@+id/textField1"
            style="@style/Widget.Design.TextInputLayout"


            android:focusableInTouchMode="true"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="2dp"
            app:backgroundTint="@null"
            app:endIconDrawable="@drawable/ic_baseline_phone_enabled_24"
            app:endIconMode="custom"
            android:textColor="?android:attr/textColorPrimary"

            android:hint="Mobile No">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtName"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginTop="40dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"
                android:focusable="true"
                android:importantForAutofill="no"


                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>





