            <TextView
                android:id="@+id/lblPoll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="10"
                android:layout_gravity="left"
                android:importantForAutofill="no"

                android:layout_marginTop="10dp"
                android:visibility="gone"
                android:text="Polling Unit:*" />



            <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
                android:id="@+id/spinner5"
                android:layout_width="match_parent"

                android:layout_marginBottom="20px"

                android:layout_height="wrap_content"
                android:background="@xml/spinner_style"
                android:layout_marginTop="2dp"
                android:prompt="@string/select3"

                app:smsp_floatingLabelColor="#000000"
                app:smsp_floatingLabelText="Polling Unit"
                app:smsp_enableFloatingLabel="true"
                app:smsp_hint="Select"
                app:smsp_hintColor="#000000"
                app:smsp_itemColor="#000000"
                app:smsp_itemListColor="#000000"
                app:smsp_itemListHintBackgroundColor="#808080"
                app:smsp_itemListHintColor="#FFFFFF"
                app:smsp_multilineError="false"
                app:smsp_isSearchable="true"
                app:smsp_errorText="false"
                app:smsp_arrowColor="#FFFFFF"
                app:smsp_enableErrorLabel="false"
                app:smsp_underlineColor="#FFFFFF"
                app:smsp_selectedItemListColor="#FF5252" />





            <EditText
                android:id="@+id/txtFname"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"


                android:focusable="true"
                android:gravity="left"
                android:hint="First Name"
                android:textColorHighlight="#3A622A"
                android:textColorHint="#3A622A"
                android:visibility="gone" />

            <EditText
                android:id="@+id/txtSurname"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"


                android:focusable="true"
                android:gravity="left"
                android:hint="Surname"
                android:textColorHighlight="#3A622A"
                android:textColorHint="#3A622A"
                android:visibility="gone" />


            <EditText
                android:id="@+id/txtMobileNo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:hint="Phone No"
                android:textColorHint="#3A622A"
                android:ems="10"
                android:visibility="gone"
                android:inputType="phone" />

            <EditText
                android:id="@+id/txtEmail"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:hint="Email Address"
                android:visibility="gone"
                android:textColorHint="#3A622A"
                android:ems="10"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/txtPassword"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"

                android:ems="10"
                android:hint="Password"
                android:inputType="textPassword"
                android:textColorHint="#3A622A"
                android:visibility="gone" />



            <EditText
                android:id="@+id/txtRetypePassword"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"

                android:ems="10"
                android:hint="Re-Type Password"
                android:inputType="textPassword"
                android:textColorHint="#3A622A"
                android:visibility="gone" />


            <LinearLayout
                android:id="@+id/linearLayout1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <Button
                    android:id="@+id/butCancel"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="30dp"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"

                    android:text="Cancel" />

                <!--
                <Button
                    android:id="@+id/button"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="30dp"

                    android:layout_marginLeft="50dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/button_label" />
                    -->
                <Button
                    android:id="@+id/button"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"

                    android:layout_height="50dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="15dp"
                    app:backgroundTint="@null"
                    android:background="@drawable/background_botton"
                    android:text="Next"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:textColor="#FFFFFF" />



            </LinearLayout>
