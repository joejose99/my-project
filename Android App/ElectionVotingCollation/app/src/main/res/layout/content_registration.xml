            <Spinner
                android:id="@+id/spinner3"
                android:layout_width="fill_parent"
                android:layout_height="50dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="20px"
                android:background="@xml/spinner_style"
                android:prompt="@string/select3" />
    -->

            <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
                android:id="@+id/spinner2"
                android:layout_width="match_parent"

                android:layout_marginBottom="20px"

                android:layout_height="wrap_content"
                android:background="@xml/spinner_style"
                android:layout_marginTop="25dp"
                android:prompt="@string/select2"

                app:smsp_floatingLabelColor="#000000"
                app:smsp_floatingLabelText="State"
                app:smsp_enableFloatingLabel="true"
                app:smsp_hint="Select"
                app:smsp_hintColor="#000000"
                app:smsp_itemColor="#000000"
                app:smsp_itemListColor="#000000"
                app:smsp_itemListHintBackgroundColor="#808080"
                app:smsp_itemListHintColor="#FFFFFF"
                app:smsp_multilineError="false"
                app:smsp_isSearchable="true"
                app:smsp_errorText="false"
                app:smsp_arrowColor="#FFFFFF"
                app:smsp_enableErrorLabel="false"
                app:smsp_underlineColor="#FFFFFF"
                app:smsp_selectedItemListColor="#FF5252" />



            <!--

            app:smsp_floatingLabelColor="#000000"
                app:smsp_floatingLabelText="State"
                app:smsp_enableFloatingLabel="true"
