<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">


    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:layout_width="fill_parent"
            android:layout_height="match_parent"

            android:clickable="true"
            android:focusableInTouchMode="true">
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusableInTouchMode="true">


            <LinearLayout
                android:id="@+id/linearLayout3"
                android:layout_width="fill_parent"
                android:orientation="horizontal"
                android:layout_height="50dp"
                android:layout_marginLeft="10dp" >

            <Button
                android:id="@+id/btnBack"

                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="41dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:background="@color/transparents"
                app:backgroundTint="@null"
                android:drawableRight="@drawable/ic_baseline_keyboard_backspace_24"
                android:textColor="#D91F2B"
                android:textSize="54sp" />


            <TextView
                android:id="@+id/txtLogin"
                android:layout_width="124dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="150dp"
                android:layout_marginTop="-34dp"

                android:textColor="?android:attr/textColorPrimary"
                android:ems="10"
                android:text="Voting Results"

                android:textSize="17sp"
                android:textStyle="bold|italic" />



        </LinearLayout>





        <TextView
            android:id="@+id/txtType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:layout_gravity="left"
            android:importantForAutofill="no"

            android:layout_marginTop="1dp"
            android:visibility="gone"
            android:text="@string/select" />



        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
            android:id="@+id/spinner1"
            android:layout_width="match_parent"

            android:layout_marginBottom="10px"

            android:layout_height="60dp"
            android:background="@xml/spinner_style"
            android:layout_marginTop="2dp"
            android:prompt="@string/select"

            app:smsp_floatingLabelColor="#000000"
            app:smsp_floatingLabelText="Election Type"
            app:smsp_enableFloatingLabel="true"
            app:smsp_hint="Select"
            app:smsp_hintColor="#000000"
            app:smsp_itemColor="#000000"
            app:smsp_itemListColor="#000000"
            app:smsp_itemListHintBackgroundColor="#808080"
            app:smsp_itemListHintColor="#FFFFFF"
            app:smsp_multilineError="false"
            app:smsp_isSearchable="true"
            app:smsp_errorText="false"
            app:smsp_arrowColor="#FFFFFF"
            app:smsp_enableErrorLabel="false"
            app:smsp_underlineColor="#FFFFFF"
            app:smsp_selectedItemListColor="#FF5252" />





        <TextView
            android:id="@+id/txtCateogry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:layout_gravity="left"
            android:importantForAutofill="no"

            android:layout_marginTop="1dp"
            android:visibility="gone"
            android:text="@string/select6" />



        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
            android:id="@+id/spinner6"
            android:layout_width="match_parent"

            android:layout_marginBottom="10px"

            android:layout_height="60dp"
            android:background="@xml/spinner_style"
            android:layout_marginTop="2dp"
            android:prompt="@string/select6"

            app:smsp_floatingLabelColor="#000000"
            app:smsp_floatingLabelText="Election Category"
            app:smsp_enableFloatingLabel="true"
            app:smsp_hint="Select"
            app:smsp_hintColor="#000000"
            app:smsp_itemColor="#000000"
            app:smsp_itemListColor="#000000"
            app:smsp_itemListHintBackgroundColor="#808080"
            app:smsp_itemListHintColor="#FFFFFF"
            app:smsp_multilineError="false"
            app:smsp_isSearchable="true"
            app:smsp_errorText="false"
            app:smsp_arrowColor="#FFFFFF"
            app:smsp_enableErrorLabel="false"
            app:smsp_underlineColor="#FFFFFF"
            app:smsp_selectedItemListColor="#FF5252" />





        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:layout_gravity="left"
            android:importantForAutofill="no"
android:visibility="gone"
            android:layout_marginTop="1dp"

            android:text="State:*" />

        <!--
        <Spinner
            android:id="@+id/spinner3"
            android:layout_width="fill_parent"
            android:layout_height="50dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="20px"
            android:background="@xml/spinner_style"
            android:prompt="@string/select3" />
-->

        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
            android:id="@+id/spinner2"
            android:layout_width="match_parent"

            android:layout_marginBottom="10px"

            android:layout_height="60dp"
            android:background="@xml/spinner_style"
            android:layout_marginTop="2dp"
            android:prompt="@string/select2"

            app:smsp_floatingLabelColor="#000000"
            app:smsp_floatingLabelText="State"
            app:smsp_enableFloatingLabel="true"
            app:smsp_hint="Select"
            app:smsp_hintColor="#000000"
            app:smsp_itemColor="#000000"
            app:smsp_itemListColor="#000000"
            app:smsp_itemListHintBackgroundColor="#808080"
            app:smsp_itemListHintColor="#FFFFFF"
            app:smsp_multilineError="false"
            app:smsp_isSearchable="true"
            app:smsp_errorText="false"
            app:smsp_arrowColor="#FFFFFF"
            app:smsp_enableErrorLabel="false"
            app:smsp_underlineColor="#FFFFFF"
            app:smsp_selectedItemListColor="#FF5252" />

        <!--
        <Spinner
            android:id="@+id/spinner3"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"

            android:layout_marginTop="2dp"
            android:prompt="@string/select3" />
-->
        <TextView
            android:id="@+id/lbltLGA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"

            android:importantForAutofill="no"
            android:layout_gravity="left"
            android:layout_marginTop="1dp"
android:visibility="gone"
            android:text="LGA:*" />



        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
            android:id="@+id/spinner3"
            android:layout_width="match_parent"

            android:layout_marginBottom="10px"

            android:layout_height="60dp"
            android:background="@xml/spinner_style"
            android:layout_marginTop="2dp"
            android:prompt="@string/select3"

            app:smsp_floatingLabelColor="#000000"
            app:smsp_floatingLabelText="LGA"
            app:smsp_enableFloatingLabel="true"
            app:smsp_hint="Select"
            app:smsp_hintColor="#000000"
            app:smsp_itemColor="#000000"
            app:smsp_itemListColor="#000000"
            app:smsp_itemListHintBackgroundColor="#808080"
            app:smsp_itemListHintColor="#FFFFFF"
            app:smsp_multilineError="false"
            app:smsp_isSearchable="true"
            app:smsp_errorText="false"
            app:smsp_arrowColor="#FFFFFF"
            app:smsp_enableErrorLabel="false"
            app:smsp_underlineColor="#FFFFFF"
            app:smsp_selectedItemListColor="#FF5252" />




<!--
        <Spinner
            android:id="@+id/spinner4"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:prompt="@string/select4" />

            -->
        <TextView
            android:id="@+id/lblWard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"

            android:importantForAutofill="no"
            android:layout_gravity="left"
            android:layout_marginTop="1dp"
android:visibility="gone"
            android:text="Ward:*" />



        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
            android:id="@+id/spinner4"
            android:layout_width="match_parent"

            android:layout_marginBottom="20px"

            android:layout_height="60dp"
            android:background="@xml/spinner_style"
            android:layout_marginTop="10dp"
            android:prompt="@string/select4"

            app:smsp_floatingLabelColor="#000000"
            app:smsp_floatingLabelText="Ward"
            app:smsp_enableFloatingLabel="true"
            app:smsp_hint="Select"
            app:smsp_hintColor="#000000"
            app:smsp_itemColor="#000000"
            app:smsp_itemListColor="#000000"
            app:smsp_itemListHintBackgroundColor="#808080"
            app:smsp_itemListHintColor="#FFFFFF"
            app:smsp_multilineError="false"
            app:smsp_isSearchable="true"
            app:smsp_errorText="false"
            app:smsp_arrowColor="#FFFFFF"
            app:smsp_enableErrorLabel="false"
            app:smsp_underlineColor="#FFFFFF"
            app:smsp_selectedItemListColor="#FF5252" />


<!--
        <Spinner
            android:id="@+id/spinner5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.78"
            android:prompt="@string/select5" />
            -->

        <TextView
            android:id="@+id/lblPoll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
android:layout_gravity="left"
            android:importantForAutofill="no"

            android:layout_marginTop="1dp"
android:visibility="gone"
            android:text="Polling Unit:*" />



        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
            android:id="@+id/spinner5"
            android:layout_width="match_parent"

            android:layout_marginBottom="10px"

            android:layout_height="60dp"
            android:background="@xml/spinner_style"
            android:layout_marginTop="2dp"
            android:prompt="@string/select5"

            app:smsp_floatingLabelColor="#000000"
            app:smsp_floatingLabelText="Polling Unit"
            app:smsp_enableFloatingLabel="true"
            app:smsp_hint="Select"
            app:smsp_hintColor="#000000"
            app:smsp_itemColor="#000000"
            app:smsp_itemListColor="#000000"
            app:smsp_itemListHintBackgroundColor="#808080"
            app:smsp_itemListHintColor="#FFFFFF"
            app:smsp_multilineError="false"
            app:smsp_isSearchable="true"
            app:smsp_errorText="false"
            app:smsp_arrowColor="#FFFFFF"
            app:smsp_enableErrorLabel="false"
            app:smsp_underlineColor="#FFFFFF"
            app:smsp_selectedItemListColor="#FF5252" />





        <EditText
            android:id="@+id/txtFname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"


            android:focusable="true"
            android:gravity="left"
            android:hint="First Name"
            android:textColorHighlight="#3A622A"
            android:textColorHint="#3A622A"
            android:visibility="gone" />

        <EditText
            android:id="@+id/txtSurname"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"


            android:focusable="true"
            android:gravity="left"
            android:hint="Surname"
            android:textColorHighlight="#3A622A"
            android:textColorHint="#3A622A"
            android:visibility="gone" />


        <EditText
            android:id="@+id/txtMobileNo"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:hint="Phone No"
            android:textColorHint="#3A622A"
            android:ems="10"
            android:visibility="gone"
            android:inputType="phone" />

        <EditText
            android:id="@+id/txtEmail"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:hint="Email Address"
            android:visibility="gone"
            android:textColorHint="#3A622A"
            android:ems="10"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/txtPassword"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"

            android:ems="10"
            android:hint="Password"
            android:inputType="textPassword"
            android:textColorHint="#3A622A"
            android:visibility="gone" />



        <EditText
            android:id="@+id/txtRetypePassword"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"

            android:ems="10"
            android:hint="Re-Type Password"
            android:inputType="textPassword"
            android:textColorHint="#3A622A"
            android:visibility="gone" />








        <CheckBox
            android:id="@+id/checkBox"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:layout_marginRight="100dp"
            android:layout_marginTop="3dp"

            android:layout_weight="0.78"

            android:background="@color/transparents"
            android:text="Party-Result"


            android:textSize="15dp" />


        <!--
        <EditText
            android:id="@+id/txtMsg"
            android:layout_width="fill_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="25dp"
            android:layout_weight="2.65"
            android:ems="10"
            android:gravity="top"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:backgroundTint="@null"
            android:hint="Polling Results"
            android:inputType="textMultiLine"
            android:scrollbars = "vertical"

            android:lines="5"
            android:text="@string/message" />

            -->


        <TextView
            android:id="@+id/txtFormat"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="80dp"

            android:layout_marginTop="-38dp"


            android:text="Format (PDP:500,)"
            android:textSize="18dp"
            android:textStyle="bold|italic"
            app:backgroundTint="@null" />

        <com.google.android.material.textfield.TextInputLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/transparents"


                app:hintTextColor="@color/boxStrokeColor"
                app:boxStrokeColor="@color/boxStrokeColor"
                android:id="@+id/textField4"
                style="@style/Widget.Design.TextInputLayout"


                android:focusableInTouchMode="true"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="2dp"
                app:backgroundTint="@null"

                app:endIconMode="custom"
                android:textColor="?android:attr/textColorPrimary"
                android:inputType="textMultiLine"
                android:scrollbars = "vertical"
                android:hint="Polling Results">

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/txtMsg"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginTop="40dp"
                        android:layout_marginRight="20dp"
                        android:layout_marginLeft="20dp"
                        android:focusable="true"
                        android:importantForAutofill="no"

                        android:inputType="textMultiLine"
                        android:scrollbars = "vertical"

                        android:maxLines="6"
                        android:minLines="5"

                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"

                        />
            </com.google.android.material.textfield.TextInputLayout>







            <Button
                android:id="@+id/butCancel"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:layout_marginTop="10dp"
android:visibility="gone"
                android:text="Cancel" />




            <Button
                android:id="@+id/button"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="match_parent"

                android:layout_height="50dp"
                android:layout_alignParentBottom="true"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="30dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="15dp"
                app:backgroundTint="@null"
                android:background="@drawable/background_botton"
                android:text="Next"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="#FFFFFF" />


            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

