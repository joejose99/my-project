<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:background="@drawable/card_background"
    android:elevation="3dp">

    <ImageView
        android:id="@+id/pic"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title" />

    <TextView
        android:id="@+id/category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="4dp"
        android:gravity="center"
        android:text="category"
        android:textAlignment="center"
        android:textColor="#FE6E17"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="4dp"
        android:gravity="center"
        android:text="title"
        android:textAlignment="center"
        android:textColor="#373b54"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/category" />

    <!-- PDP -->

    <TextView
        android:id="@+id/fee_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Result"
        android:textColor="#FE6E17"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title" />

    <TextView
        android:id="@+id/textView14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="3dp"
        android:text="PDP"
        android:textColor="#373b54"
        app:layout_constraintBottom_toBottomOf="@+id/fee_2"
        app:layout_constraintEnd_toStartOf="@+id/fee_2"
        app:layout_constraintTop_toBottomOf="@+id/title" />

    <!-- APC -->

    <TextView
        android:id="@+id/fee_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Result"
        android:textColor="#FE6E17"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView14" />

    <TextView
        android:id="@+id/textView13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="3dp"
        android:text="APC"
        android:textColor="#373b54"
        app:layout_constraintBottom_toBottomOf="@+id/fee_1"
        app:layout_constraintEnd_toStartOf="@+id/fee_1"
        app:layout_constraintTop_toBottomOf="@+id/textView14" />

    <!-- LP -->

    <TextView
        android:id="@+id/fee_10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Result"
        android:textColor="#FE6E17"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView13" />

    <TextView
        android:id="@+id/textView16"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="3dp"
        android:text="LP"
        android:textColor="#373b54"
        app:layout_constraintBottom_toBottomOf="@+id/fee_10"
        app:layout_constraintEnd_toStartOf="@+id/fee_10"
        app:layout_constraintTop_toBottomOf="@+id/textView13" />

    <!-- ADC -->

    <TextView
        android:id="@+id/fee_adc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Result"
        android:textColor="#FE6E17"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView16" />

    <TextView
        android:id="@+id/textViewADC"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="3dp"
        android:text="ADC"
        android:textColor="#373b54"
        app:layout_constraintBottom_toBottomOf="@+id/fee_adc"
        app:layout_constraintEnd_toStartOf="@+id/fee_adc"
        app:layout_constraintTop_toBottomOf="@+id/textView16" />

    <!-- Others -->

    <TextView
        android:id="@+id/fee_0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Result"
        android:textColor="#FE6E17"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewADC" />

    <TextView
        android:id="@+id/textView12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="3dp"
        android:text="Others"
        android:textColor="#373b54"
        app:layout_constraintBottom_toBottomOf="@+id/fee_0"
        app:layout_constraintEnd_toStartOf="@+id/fee_0"
        app:layout_constraintTop_toBottomOf="@+id/textViewADC" />

    <!-- Total -->

    <TextView
        android:id="@+id/lbltotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Result"
        android:textColor="#4CAF50"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView12" />

    <TextView
        android:id="@+id/textView11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="3dp"
        android:text="Total"
        android:textColor="#373b54"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/lbltotal"
        app:layout_constraintEnd_toStartOf="@+id/lbltotal"
        app:layout_constraintTop_toBottomOf="@+id/textView12" />

    <TextView
        android:id="@+id/addBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        android:background="@drawable/add_button_bg"
        android:paddingStart="10dp"
        android:paddingTop="7dp"
        android:paddingEnd="10dp"
        android:paddingBottom="7dp"
        android:text="  + Click  "
        android:textColor="#ffffff"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView11" />

</androidx.constraintlayout.widget.ConstraintLayout>