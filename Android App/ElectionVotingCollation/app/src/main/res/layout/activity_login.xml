<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="match_parent"
    android:background="#1D3114" >

<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="match_parent"
    android:layout_margin="10dp"
    android:gravity="center"
    android:orientation="vertical" >

    <TextView
        android:id="@+id/txtLogin"
        android:layout_width="284dp"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:ems="10"
        android:gravity="left"
        android:text="Login"
        android:textColor="#F5F8F4"
        android:textSize="19dp"/>
        
     

    <EditText
    android:id = "@+id/txtInd" 
       android:text = "INDEPENDENT" android:layout_width="wrap_content"
      android:layout_height = "wrap_content"
      android:background="@color/colorPrimary"
      android:textSize = "25dp"
      android:textColor="#F7FAF7"
       android:layout_marginTop="25dp"  
      android:layout_alignParentTop = "true"
      android:layout_centerHorizontal = "true" />
    
    <EditText
    android:id = "@+id/txtNat" 
       android:text = "National Electoral Commission" android:layout_width="wrap_content"
      android:layout_height = "wrap_content"
      android:background="@color/colorPrimary"
      android:textColor="#AAD9A2"
      android:textSize = "18dp"
      android:layout_alignParentTop = "true"
      android:layout_centerHorizontal = "true" />
     
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="504dp"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_marginTop="15dp"
        android:layout_weight="0.92"
        android:src="@drawable/login_logo1" />

 <EditText
     android:id="@+id/txtName"
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:layout_alignParentEnd="true"
     android:layout_alignParentLeft="true"
     android:layout_alignParentRight="true"
     android:layout_alignParentStart="true"
     android:layout_below="@+id/imageView"
     android:layout_marginTop="46dp"
     android:focusable="true"
     android:hint="User Name"
     android:textColorHighlight="#3A622A"
     android:textColorHint="#3A622A" />
 
   <EditText
       android:id="@+id/txtPassword"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:layout_alignParentLeft="true"
       android:layout_alignParentStart="true"
       android:layout_alignRight="@+id/txtName"
       android:layout_below="@+id/txtName"
       android:layout_marginTop="25dp"
       android:ems="10"
       android:hint="Password"
       android:inputType="textPassword"
       android:textColorHint="#3A622A" />
   
    <Button
        android:id="@+id/button"
        android:layout_width="120dp"
        android:layout_height="wrap_content" 
        android:layout_marginTop="15dp"
        android:layout_marginBottom="10dp"
        android:text="@string/button_label"/>
 </LinearLayout>
</ScrollView>
