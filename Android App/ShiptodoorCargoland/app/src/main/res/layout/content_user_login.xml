<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".UserLogin"

    android:background="@drawable/background_login"
    tools:showIn="@layout/activity_user_login">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"

        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
<!--
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:clickable="true"
            android:focusableInTouchMode="true">
-->

            <LinearLayout
                android:id="@+id/linearLayout3"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"

                android:layout_margin="10dp"
                android:layout_marginLeft="10dp"


                android:orientation="vertical">






                <Button
                    android:id="@+id/button2"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="34dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:background="#ffffff"

                    android:drawableRight="@drawable/ic_baseline_keyboard_arrow_left_24"
                    android:textColor="#D91F2B"
                    android:textSize="54sp"
                    android:visibility="gone"/>


                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="fill_parent"
                    android:layout_height="90dp"
                    android:layout_alignParentStart="true"

                    android:layout_alignParentTop="true"
                    android:layout_marginLeft="0dp"
                    android:layout_marginTop="102dp"
                    android:layout_marginRight="0dp"
                    android:layout_marginBottom="18dp"
                    android:src="@drawable/logo2" />

                <!-- android:src="@drawable/logo_user2" -->

                <EditText
                    android:id="@+id/txtName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/imageView"


                    android:layout_alignParentStart="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="30dp"
                    android:width="140px"


                    android:background="@xml/text_style"

                    android:focusable="true"
                    android:hint="Mobile No"
                    android:inputType="phone"
                    android:minHeight="45dp"
                    android:padding="15dp"

                    android:textColor="#000000"
                    android:textColorHint="#C1C1C1"
                    android:visibility="visible" />

                <EditText
                    android:id="@+id/txtPassword"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:layout_below="@+id/txtName"
                    android:layout_alignRight="@+id/txtName"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="25dp"
                    android:background="@xml/text_style"
                    android:ems="10"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:minHeight="45dp"


                    android:padding="15dp"
                    android:textColor="#000000"
                    android:textColorHint="#C1C1C1"

                    android:visibility="visible" />


                <LinearLayout
                    android:id="@+id/linearLayout1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">


                    <Button
                        android:id="@+id/button"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="90dp"

                        android:layout_height="50dp"
                        android:layout_alignParentBottom="true"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="40dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginBottom="10dp"

                        android:background="@drawable/background_botton"
                        android:text="Log in "
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                        android:textColor="#FFFFFF" />


                    <Button
                        android:id="@+id/butFog"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="90dp"

                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="40dp"
                        android:layout_marginBottom="10dp"
                        android:background="#FFFFFF"
                        android:text="Forgot"
                        android:textColor="#780A09" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/linear_Layout4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/butReg"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="90dp"

                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="40dp"
                        android:background="@drawable/botton_bg"
                        android:text="Register"
                        android:textColor="#FFFFFF" />

                </LinearLayout>


            </LinearLayout>
<!--
        </ScrollView>
        -->
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>